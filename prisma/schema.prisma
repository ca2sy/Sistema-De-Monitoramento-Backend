generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model projeto {
  id         Int             @id @default(autoincrement())
  nome       String          @db.VarChar(200)
  descricao  String?         @db.VarChar(500)
  ativo      Boolean         @default(true)
  criadoEm   DateTime        @default(now())
  tipos      tipoAquisicao[]
  aquisicoes aquisicao[]
}

model tipoAquisicao {
  id         Int              @id @default(autoincrement())
  nome       String           @db.VarChar(300)
  projetoId  Int
  projeto    projeto          @relation(fields: [projetoId], references: [id])
  etapas     etapaAquisicao[]
  aquisicoes aquisicao[]
}

model etapaAquisicao {
  id              Int             @id @default(autoincrement())
  nome            String          @db.VarChar(100)
  ordem           Int
  tipoAquisicaoId Int
  tipoAquisicao   tipoAquisicao   @relation(fields: [tipoAquisicaoId], references: [id])
  subEtapas       subEtapa[]
  aquisicoes      aquisicao[]
}

model subEtapa {
  id               Int            @id @default(autoincrement())
  descricao        String         @db.VarChar(300)
  ordem            Int            @default(0)
  etapaAquisicaoId Int
  etapaAquisicao   etapaAquisicao @relation(fields: [etapaAquisicaoId], references: [id])
  respostas        aquisicaoChecklist[]
}

model aquisicao {
  codigo                    String               @id @db.VarChar(80)
  projetoId                 Int
  projeto                   projeto              @relation(fields: [projetoId], references: [id])
  tipoAquisicaoId           Int
  tipoAquisicao             tipoAquisicao        @relation(fields: [tipoAquisicaoId], references: [id])
  etapaAquisicaoId          Int
  etapaAquisicao            etapaAquisicao       @relation(fields: [etapaAquisicaoId], references: [id])
  descricaoObjetoNome       String               @db.VarChar(100)
  valorEstimado             Decimal
  responsavel               String               @db.VarChar(200)
  dataLimite                DateTime
  statusAquisicaoId         Int
  statusAquisicao           statusAquisicao      @relation(fields: [statusAquisicaoId], references: [id])
  secretariaId              Int
  secretaria                secretaria           @relation(fields: [secretariaId], references: [id])
  cancelado                 Boolean              @default(false)
  justificativaCancelamento String?              @db.VarChar(500)
  aquisicaoChecklists       aquisicaoChecklist[]
}

model aquisicaoChecklist {
  id          Int       @id @default(autoincrement())
  aquisicaoCodigo String
  aquisicao   aquisicao @relation(fields: [aquisicaoCodigo], references: [codigo])
  subEtapaId  Int
  subEtapa    subEtapa  @relation(fields: [subEtapaId], references: [id])
  concluido   Boolean   @default(false)
  concluidoEm DateTime?

  @@unique([aquisicaoCodigo, subEtapaId])
}


model statusAquisicao {
  id         Int         @id @default(autoincrement())
  nome       String      @db.VarChar(100)
  aquisicoes aquisicao[]
}

model secretaria {
  id         Int         @id @default(autoincrement())
  nome       String      @db.VarChar(100)
  aquisicoes aquisicao[]
}

model usuario {
  id     Int     @id @default(autoincrement())
  nome   String  @db.VarChar(250)
  senha  String  @db.VarChar(250)
}